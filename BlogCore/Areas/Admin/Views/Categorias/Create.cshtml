@model BlogCoreSolution.Models.Category

@{
    ViewData["Title"] = "Create Category";
}

<div>
    <h2 class="text-center">Create new category</h2>
    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        <div class="row px-2 offset-1 border">
            <div asp-validation-summary="All" class="text-danger">
                <div class="col-10 offset-1 mt-4">
                    <div class="form-group row">
                        <div class="col-4">
                            <label asp-for="Name"></label>
                        </div>
                        <div class="col-4">
                            <input asp-for="Name" class="form-control" placeholder="Category name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        
                        <div class="col-4">
                            <label asp-for="Order"></label>
                        </div>
                        <div class="col-4">
d                            <input asp-for="Order" class="form-control" placeholder="Order" />
                            <span asp-validation-for="Order" class="text-danger"></span>
                        </div>
                        
                    </div>
                    
                    <div class="form-group-row mt-3">
                        <div class="col-8">
                            <partial name="_ViewCreateBack"/>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}