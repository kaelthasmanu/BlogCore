@{
    ViewData["Title"] = "Article List";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-8">
            <h2 class="text-primary">Article List</h2>
        </div>
        <div class="col-4 text-right">
            <a asp-area="Admin" asp-controller="Articles" asp-action="Create" class="btn btn-success">Create New Article</a>
        </div>
    </div>
    <br />
    <table id="tblArticulos" class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Category</th>
                <th>Image</th>
                <th>Create At</th>
                <th>Actions</th>
            </tr>
        </thead>
    </table>
</div>

@section Scripts {
    <script src="~/js/articles.js"></script>
}