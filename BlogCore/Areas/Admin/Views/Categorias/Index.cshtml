@{
    ViewData["Title"] = "Category List";
}

<!DOCTYPE html>

<html>
<head>
    <title>Category List</title>
</head>
<body>
<div>
    <div class="container mt-4">
        <div class="row">
            <div class="col-8">
                <h2 class="text-primary">Category List</h2>
            </div>
        </div>
        <div class="col-4 text-right">
            <a asp-area="Admin" asp-controller="Categorias" asp-action="Create" class="btn btn-success">Create New Category</a>
        </div>
        <br/>
        <br/>
        <table id="tblCategorias" class="table table-striped table-bordered">
            <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Order</th>
                <th>Actions</th>
            </tr>
            </thead>
        </table>
        
    </div>
</div>
</body>
</html>


@section Scripts
{
    <script src="~/js/categories.js"> </script>
}


